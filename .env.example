# PostgreSQL connection string.
# On Replit: enable the built-in Database (Tools → Database → PostgreSQL) and Replit auto-injects this.
# Locally: run any Postgres (Docker, Postgres.app) and point this at it.
DATABASE_URL="postgresql://USER:PASS@HOST:5432/DBNAME?sslmode=require"

# Site URL — Replit subdomain in dev, custom domain in prod. NO trailing slash.
NEXT_PUBLIC_SITE_URL="https://radnar-supply.replit.app"

# 64-char random hex used for session + cart signing (openssl rand -hex 32)
AUTH_SECRET=""

# Stripe — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY: the "Secret key" (sk_live_… in production, sk_test_… for testing).
# STRIPE_WEBHOOK_SECRET: from the webhook endpoint you create pointing at
#   {NEXT_PUBLIC_SITE_URL}/api/webhooks/stripe (whsec_…).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend — https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Radnar Supply <hello@radnarsupply.com>"

# Where sourcing / personal-shopping enquiries are emailed (defaults to EMAIL_FROM address).
SOURCING_INBOX="hello@radnarsupply.com"

# UploadThing — https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=""

# Google Analytics 4 (optional in dev)
NEXT_PUBLIC_GA_ID=""
