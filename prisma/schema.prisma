generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum RequestType {
  STANDARD
  PRIVATE
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  QUOTED
  SOURCED
  CLOSED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  name            String?
  phone           String?
  role            UserRole @default(CUSTOMER)
  emailVerifiedAt DateTime?
  createdAt       DateTime @default(now())
  sessions        Session[]
  orders          Order[]
  addresses       Address[]
  tokens          VerificationToken[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  @@index([userId])
}

model Address {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  name      String
  line1     String
  line2     String?
  city      String
  postcode  String
  country   String  @default("GB")
  phone     String?
  isDefault Boolean @default(false)
  orders    Order[]
  @@index([userId])
}

model Brand {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  logoUrl     String?
  products    Product[]
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  parentId    String?
  parent      Category?  @relation("CatTree", fields: [parentId], references: [id])
  children    Category[] @relation("CatTree")
  products    Product[]
}

model Product {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String
  priceCents  Int
  brandId     String
  brand       Brand          @relation(fields: [brandId], references: [id])
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    Variant[]
  stockNotices StockNotice[]
  active      Boolean        @default(true)
  featured    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  @@index([brandId, categoryId, active])
}

// Back-in-stock: a shopper asks to be emailed when a sold-out product returns.
model StockNotice {
  id         String    @id @default(cuid())
  email      String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?
  @@unique([productId, email])
  @@index([productId, notifiedAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  key       String
  alt       String?
  position  Int     @default(0)
  @@index([productId, position])
}

model Variant {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  sku       String      @unique
  stock     Int         @default(0)
  items     OrderItem[]
  @@unique([productId, size])
}

model Order {
  id                String         @id @default(cuid())
  number            String         @unique
  user              User?          @relation(fields: [userId], references: [id])
  userId            String?
  email             String
  status            OrderStatus    @default(PENDING)
  paymentStatus     PaymentStatus  @default(PENDING)
  subtotalCents     Int
  shippingCents     Int
  totalCents        Int
  currency          String         @default("GBP")
  shippingAddress   Address?       @relation(fields: [shippingAddressId], references: [id])
  shippingAddressId String?
  shipName          String
  shipLine1         String
  shipLine2         String?
  shipCity          String
  shipPostcode      String
  shipCountry       String         @default("GB")
  shipPhone         String?
  stripeSessionId   String?        @unique
  stripePaymentIntentId String?    @unique
  paymentMethod    String?
  notes             String?
  trackingCarrier   String?
  trackingNumber    String?
  trackingUrl       String?
  refundedCents     Int            @default(0)
  abandonedNotifiedAt DateTime?    // abandoned-checkout reminder sent
  items             OrderItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id             String  @id @default(cuid())
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  variant        Variant @relation(fields: [variantId], references: [id])
  variantId      String
  productName    String
  brandName      String
  size           String
  imageUrl       String
  unitPriceCents Int
  quantity       Int
  @@index([orderId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  prefix     String
  hash       String    @unique
  scopes     String                  // csv of: read, write, delete
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  createdBy  String?
  webhooks   Webhook[]
  @@index([prefix])
  @@index([revokedAt])
}

model Webhook {
  id         String    @id @default(cuid())
  apiKey     ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  apiKeyId   String
  url        String                  // destination URL for event POSTs
  events     String                  // csv: order.paid,order.shipped,product.updated,inventory.changed,…
  secret     String                  // HMAC signing key (returned only on creation)
  active     Boolean   @default(true)
  lastFiredAt DateTime?
  lastStatus  Int?                   // last HTTP status received
  createdAt  DateTime  @default(now())
  @@index([apiKeyId])
  @@index([active])
}

// Personal-shopping / sourcing enquiries (incl. RADNAR Private luxury requests)
model SourcingRequest {
  id          String        @id @default(cuid())
  type        RequestType   @default(STANDARD)
  status      RequestStatus @default(NEW)
  name        String
  email       String
  phone       String?
  item        String                  // what they're looking for
  size        String?
  budget      String?                 // free-text budget / target price
  detail      String?                 // extra notes from the requester
  imageUrls   String        @default("[]") // JSON array of UploadThing URLs
  notes       String?                 // internal admin notes
  quoteCents  Int?                    // admin-set price quoted to the customer
  quoteDetail String?                 // what's being quoted (item summary shown to customer)
  quoteUrl    String?                 // Stripe Payment Link the customer can pay
  quoteRemindedAt DateTime?           // quote-follow-up reminder sent
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@index([status, createdAt])
  @@index([type, createdAt])
}

// SEO blog
model Post {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?
  body            String                  // markdown / plain text
  coverImage      String?
  coverImageKey   String?
  published       Boolean   @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([published, publishedAt])
}
